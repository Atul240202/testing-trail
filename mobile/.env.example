# Google OAuth 2.0 Configuration
# Get these credentials from Google Cloud Console: https://console.cloud.google.com/

# Web Client ID (for OAuth configuration)
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# iOS Client ID (for iOS app)
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Android Client ID (for Android app)
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# API Configuration
# For Android Emulator use: http://10.0.2.2:5001/api/v1
# For iOS Simulator or localhost use: http://localhost:5001/api/v1
# For physical devices, set your computer's local IP address:
# Example: API_BASE_URL=http://192.168.1.100:5001/api/v1
# To find your IP:
# - macOS/Linux: ifconfig | grep "inet " | grep -v 127.0.0.1
# - Windows: ipconfig
# 
# For production, use your production API URL:
# Example: API_BASE_URL=https://api.yourapp.com/api/v1
API_BASE_URL=http://10.0.2.2:5001/api/v1

# Background Worker Configuration
# Health data collection interval in minutes (default: 15)
# Data is collected every 15 minutes and synced to backend every 1 hour
HEALTH_DATA_FETCH_INTERVAL=15

# Background worker task ID
BACKGROUND_TASK_ID=com.pause.healthdata.fetch

# AsyncStorage key for health data queue
HEALTH_DATA_STORAGE_KEY=@pause_health_data_queue

# Health Data Sync Configuration
# Batch size for uploading health data (default: 50, max: 100)
HEALTH_DATA_BATCH_SIZE=50

# Maximum retry attempts for failed uploads (default: 3)
HEALTH_DATA_MAX_RETRIES=3

# Initial retry delay in milliseconds (default: 1000, doubles with each retry)
HEALTH_DATA_RETRY_DELAY=1000
